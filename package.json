{
  "name": "media-triage",
  "version": "1.0.0",
  "description": "Local media triage tool — sort your library without moving anything",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others -n server,client -c cyan,yellow \"node server/index.js\" \"vite client\"",
    "dev:bg": "npm run dev > triage.log 2>&1 & echo $! > triage.pid && echo 'Started. Logs: triage.log  |  Stop: npm run stop'",
    "stop": "fuser -k 3001/tcp 5173/tcp 2>/dev/null; rm -f triage.pid; echo Stopped",
    "build": "vite build client",
    "start": "NODE_ENV=production node server/index.js",
    "test": "node --test server/scanner.test.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "fast-glob": "^3.3.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.2.11"
  }
}
